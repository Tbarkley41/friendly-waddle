  "templates": {
    "Consulting": {
      "TemplateID":    "TPL-CONSULTING-01",
      "Description":  "High-trust, authority-first layout for B2B consulting firms.",
      "ConversionGoal": "Discovery call booking / lead form submission",
      "PageArchitecture": [
        {
          "PageType":    "Home",
          "Slug":        "/",
          "Sections":    ["Hero", "ValueProp", "Services", "SocialProof", "CTA", "Footer"],
          "Hero": {
            "HeadlineFormula": "[Outcome] for [ICP] in [Location]",
            "HeadlineExample": "Operational Clarity for Orlando SMBs",
            "SubCopy":         "We diagnose the bottlenecks holding your business back — and build the systems to eliminate them.",
            "CTAPrimary":      "Book a Free Strategy Call",
            "CTASecondary":    "See How It Works"
          },
          "SocialProof": ["Client logo strip", "2–3 short testimonials", "Result stat callouts"],
          "SEOPriority": "High"
        },
        {
          "PageType": "Service",
          "Slug":     "/services/[service-slug]",
          "Sections": ["ServiceHero", "ProblemStatement", "Solution", "Process", "Results", "CTA"],
          "SEOPriority": "High",
          "SchemaType":  "Service"
        },
        {
          "PageType": "Landing",
          "Slug":     "/[campaign-slug]",
          "Sections": ["Hero", "BenefitsList", "LeadForm", "TrustSignals"],
          "Notes":    "No navigation — conversion-only page. Agent #1 form required.",
          "SEOPriority": "Medium"
        },
        {
          "PageType": "CaseStudy",
          "Slug":     "/case-studies/[client-slug]",
          "Sections": ["Challenge", "Approach", "Outcome", "Metrics", "TestimonialQuote", "CTA"],
          "SEOPriority": "Medium",
          "SchemaType":  "Article"
        },
        {
          "PageType": "Contact",
          "Slug":     "/contact",
          "Sections": ["LeadForm", "ContactInfo", "Map"],
          "Notes":    "Primary Agent #1 intake form lives here.",
          "SEOPriority": "Low"
        }
      ],
      "CTAStructure": {
        "Primary":   { "Text": "Book a Free Strategy Call", "Action": "Calendly link or form scroll" },
        "Secondary": { "Text": "Download Our Free Audit",   "Action": "Lead magnet gated form" },
        "Tertiary":  { "Text": "See Our Results",           "Action": "Case study anchor link" }
      },
      "FormSchema": {
        "FormID":   "consulting-intake-v1",
        "Fields":   ["BusinessName", "Industry", "CoreServices", "MonthlyRevenue", "LeadCount", "CloseRate"],
        "SubmitCTA": "Get My Free Growth Analysis",
        "PostSubmit": "Thank you — we'll send your analysis within 24 hours."
      },
      "TrustElements": ["ClientLogos", "Testimonials", "CaseStudyLinks", "MediaMentions", "Certifications"],
      "TypicalPageCount": 8,
      "RecommendedColors": { "Primary": "#1A2E4A", "Accent": "#F4A623", "Background": "#F9F9F9" },
      "RecommendedFonts":  { "Heading": "Playfair Display", "Body": "Inter" }
    },
